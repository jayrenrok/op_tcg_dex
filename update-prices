name: Update eBay Prices

# Runs nightly at 02:00 UTC (10:00 AM Penang). Also runnable manually.
on:
  schedule:
    - cron: '0 2 * * *'
  workflow_dispatch:
    inputs:
      limit:
        description: 'Card limit for testing (0 = all cards)'
        required: false
        default: '0'

jobs:
  update-prices:
    runs-on: ubuntu-latest
    permissions:
      contents: write    # needed to commit prices.json back to the repo

    steps:
      - name: Checkout repository
        uses: actions/checkout@v4

      - name: Set up Python
        uses: actions/setup-python@v5
        with:
          python-version: '3.12'

      - name: Run price fetcher
        env:
          EBAY_APP_ID: ${{ secrets.EBAY_APP_ID }}
          EBAY_CERT_ID: ${{ secrets.EBAY_CERT_ID }}
          LIMIT: ${{ github.event.inputs.limit || '0' }}
        run: python fetch_prices.py

      - name: Commit and push prices.json
        run: |
          git config user.name "github-actions[bot]"
          git config user.email "github-actions[bot]@users.noreply.github.com"
          if [[ -n "$(git status --porcelain prices.json)" ]]; then
            git add prices.json
            git commit -m "chore: update prices.json [skip ci]"
            git push
            echo "Pushed updated prices.json"
          else
            echo "No changes to prices.json"
          fi